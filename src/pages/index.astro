---
// Galata Istanbul Hotel – Premium Static Site
// All room data, WhatsApp integration, and elegant design
const rooms = [
  {
    name: "Romantic Suite Room With Jacuzzi & Sea View",
    desc: "Luxurious suite perfect for couples, featuring a private Jacuzzi and breathtaking sea views.",
    img: "https://placehold.co/800x600/1a1a2e/D4AF37?text=Romantic+Suite",
    price: "€250"
  },
  {
    name: "Deluxe Double or Twin Room With Sea View",
    desc: "Experience stunning sea views with the choice of a double or twin beds, equipped with modern comforts.",
    img: "https://placehold.co/800x600/1a1a2e/D4AF37?text=Deluxe+Sea+View",
    price: "€180"
  },
  {
    name: "Deluxe Triple or Double Room with Partial Sea View",
    desc: "Accommodate up to three guests with partial sea views, featuring a combination of beds and modern comforts.",
    img: "https://placehold.co/800x600/1a1a2e/D4AF37?text=Deluxe+Triple",
    price: "€200"
  },
  {
    name: "Deluxe Big Double or Twin Room with Partial Sea View",
    desc: "Spacious room with partial sea views, offering the flexibility of double or twin beds and modern amenities.",
    img: "https://placehold.co/800x600/1a1a2e/D4AF37?text=Big+Double",
    price: "€210"
  },
  {
    name: "Business Deluxe Double or Twin Room",
    desc: "Perfect for business travelers, offering a double or twin beds, a work desk, and modern amenities.",
    img: "https://placehold.co/800x600/1a1a2e/D4AF37?text=Business+Deluxe",
    price: "€190"
  },
  {
    name: "Standard Family Triple Room",
    desc: "Spacious room for families, accommodating three guests with a combination of double and single beds.",
    img: "https://placehold.co/800x600/1a1a2e/D4AF37?text=Family+Triple",
    price: "€160"
  },
  {
    name: "Standard Double or Twin Room",
    desc: "Flexible and comfortable with a choice of double or twin beds, featuring all modern amenities.",
    img: "https://placehold.co/800x600/1a1a2e/D4AF37?text=Standard+Double",
    price: "€130"
  },
  {
    name: "Economy Double or Twin Room",
    desc: "Affordable comfort with a choice of double or twin beds, perfect for budget-conscious travelers.",
    img: "https://placehold.co/800x600/1a1a2e/D4AF37?text=Economy+Double",
    price: "€90"
  },
  {
    name: "Standard Single Room",
    desc: "Ideal for solo travelers, offering a comfortable single bed and essential amenities for a restful stay.",
    img: "https://placehold.co/800x600/1a1a2e/D4AF37?text=Single+Room",
    price: "€70"
  },
  {
    name: "Standard Double or Twin Room (Ground Floor)",
    desc: "Enjoy easy access and comfort with a choice of double or twin beds and modern amenities.",
    img: "https://placehold.co/800x600/1a1a2e/D4AF37?text=Ground+Floor+Double",
    price: "€125"
  }
];

const whatsappNumber = "905400027000";
const whatsappMessage = encodeURIComponent("Hello Galata Istanbul Hotel, I would like to book a room. Please provide availability and details.");
---

<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Galata Istanbul Hotel – Premium Accommodation in Istanbul</title>
    <meta name="description" content="Luxury boutique hotel in the heart of Istanbul, next to Galata Tower. Romantic suites, sea views, jacuzzi, and authentic Turkish hospitality." />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <!-- Tailwind via CDN + custom fonts -->
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
    <style>
      body {
        font-family: 'Inter', sans-serif;
        background-color: #0f0f1a;
        color: #f5f0e1;
      }
      h1, h2, h3, .font-serif {
        font-family: 'Playfair Display', serif;
      }
      .gold-text {
        color: #D4AF37;
      }
      .gold-bg {
        background-color: #D4AF37;
      }
      .gold-border {
        border-color: #D4AF37;
      }
      .room-card:hover img {
        transform: scale(1.05);
      }
      .room-card:hover .book-btn {
        background-color: #D4AF37;
        color: #0f0f1a;
      }
      .parallax {
        background-attachment: fixed;
        background-position: center;
        background-repeat: no-repeat;
        background-size: cover;
      }
      @media (max-width: 768px) {
        .parallax {
          background-attachment: scroll;
        }
      }
      /* Floating WhatsApp */
      .whatsapp-float {
        position: fixed;
        width: 60px;
        height: 60px;
        bottom: 40px;
        right: 40px;
        background-color: #25d366;
        color: #FFF;
        border-radius: 50px;
        text-align: center;
        font-size: 30px;
        box-shadow: 2px 2px 3px #999;
        z-index: 100;
        display: flex;
        align-items: center;
        justify-content: center;
        text-decoration: none;
        transition: all 0.3s;
      }
      .whatsapp-float:hover {
        background-color: #128C7E;
        transform: scale(1.1);
      }
    </style>
  </head>
  <body class="bg-[#0f0f1a]">
    <!-- Floating WhatsApp Icon -->
    <a href="https://wa.me/905400027000?text=Hello%20Galata%20Istanbul%20Hotel%2C%20I%20would%20like%20to%20book%20a%20room." class="whatsapp-float" target="_blank" aria-label="Chat on WhatsApp">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 448 512" fill="white" width="30" height="30"><path d="M380.9 97.1C339 55.1 283.2 32 223.9 32c-122.4 0-222 99.6-222 222 0 39.1 10.2 77.3 29.6 111L0 480l117.7-30.9c32.7 17.8 69.9 27.1 107.9 27.1h.1c122.3 0 222-99.6 222-222 0-59.3-24-115-67.1-157.1zM223.9 438C176 438 130 425.4 89.8 400.6l-7.7-4.5-67.1 17.6L32.7 348l-5.1-8.1C5.9 308.7 0 281 0 253.5 0 131.5 100.7 30.8 223.9 30.8c59.8 0 116 23.3 158.2 65.5S448 193.7 448 253.5c0 122-100.7 222.5-223.9 222.5h-.2zM317.6 290.5c-4.1-2-24.2-12-28-13.3-3.7-1.4-6.4-2-9.2 2-2.7 4-10.5 13.3-12.9 16-2.4 2.7-4.8 3-8.9 1-12.2-4.6-22.5-8.3-32.4-17.6-8.9-8-15.2-17.8-17.1-20.8-1.9-3-.2-4.6 1.3-6.2 1.4-1.4 3-3.8 4.5-5.7 1.5-1.9 2-3.3 3-5.5 1-2.2.5-4.1-.2-5.7-1.9-4.1-16.4-39.6-22.5-54.2-5.9-14.2-12-12.3-16.2-12.5-4.2-.2-9-.2-13.8-.2-4.8 0-12.5 1.8-19.1 9-6.5 7.2-25 24.4-25 59.5 0 35.1 25.6 69 29.1 73.7 3.6 4.8 49.4 79.8 122.7 109.1 17.1 7.4 30.5 11.8 40.9 15.1 17.1 5.4 32.7 4.7 45 2.8 13.7-2.1 42.3-17.3 48.3-34 6-16.7 6-31 4.2-34-1.8-3-6.6-5.4-10.7-7.4z"/></svg>
    </a>

    <!-- Navigation -->
    <nav class="fixed w-full z-50 bg-[#0f0f1a]/90 backdrop-blur-md border-b border-[#D4AF37]/20">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between items-center h-20">
          <a href="#" class="text-2xl font-serif font-bold gold-text tracking-wider">GALATA ISTANBUL</a>
          <div class="hidden md:flex space-x-8 text-sm font-medium uppercase tracking-wider">
            <a href="#home" class="hover:text-[#D4AF37] transition">Home</a>
            <a href="#about" class="hover:text-[#D4AF37] transition">About Us</a>
            <a href="#services" class="hover:text-[#D4AF37] transition">Services</a>
            <a href="#rooms" class="hover:text-[#D4AF37] transition">Rooms</a>
            <a href="#contact" class="hover:text-[#D4AF37] transition">Contact</a>
          </div>
          <!-- Mobile menu (simplified) -->
          <div class="md:hidden">
            <button class="text-[#D4AF37]">☰</button>
          </div>
        </div>
      </div>
    </nav>

    <!-- Hero Section (Home) -->
    <section id="home" class="relative h-screen flex items-center justify-center parallax" style="background-image: linear-gradient(rgba(15,15,26,0.7), rgba(15,15,26,0.7)), url('https://images.unsplash.com/photo-1542314831-068cd1dbfeeb?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=2070&q=80');">
      <div class="text-center px-4">
        <h1 class="text-5xl md:text-7xl font-serif font-bold text-white mb-6 leading-tight">
          Comfort and Elegance<br><span class="gold-text">in the Heart of Istanbul</span>
        </h1>
        <p class="text-xl md:text-2xl text-gray-300 mb-10 max-w-2xl mx-auto">
          Boutique luxury next to Galata Tower. Indulge in breathtaking sea views, private jacuzzis, and timeless Turkish hospitality.
        </p>
        <a href="#rooms" class="inline-block gold-bg text-[#0f0f1a] font-bold px-8 py-4 rounded-full text-lg tracking-wide hover:bg-[#b8960f] transition shadow-lg">
          View Rooms
        </a>
      </div>
    </section>

    <!-- About Us Section -->
    <section id="about" class="py-24 bg-[#13132b]">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-16">
          <h2 class="text-4xl md:text-5xl font-serif font-bold gold-text mb-4">About Us</h2>
          <p class="text-gray-400 max-w-3xl mx-auto text-lg">Galata Istanbul Hotel blends centuries-old Ottoman charm with contemporary luxury. Located steps from the iconic Galata Tower, every room tells a story of Istanbul's rich heritage.</p>
        </div>
        <div class="grid md:grid-cols-3 gap-10 text-center">
          <div class="p-6 border border-[#D4AF37]/20 rounded-lg hover:border-[#D4AF37]/50 transition">
            <div class="text-4xl gold-text mb-4">🏨</div>
            <h3 class="text-xl font-semibold mb-2">Prime Location</h3>
            <p class="text-gray-400">In the vibrant Beyoğlu district, a short walk to Istiklal Street and the Bosphorus.</p>
          </div>
          <div class="p-6 border border-[#D4AF37]/20 rounded-lg hover:border-[#D4AF37]/50 transition">
            <div class="text-4xl gold-text mb-4">✨</div>
            <h3 class="text-xl font-semibold mb-2">Authentic Luxury</h3>
            <p class="text-gray-400">Hand‑picked Ottoman décor, marble bathrooms, and personalized service.</p>
          </div>
          <div class="p-6 border border-[#D4AF37]/20 rounded-lg hover:border-[#D4AF37]/50 transition">
            <div class="text-4xl gold-text mb-4">🌅</div>
            <h3 class="text-xl font-semibold mb-2">Rooftop Views</h3>
            <p class="text-gray-400">Sip Turkish tea while gazing at the Golden Horn and the old city skyline.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Services Section -->
    <section id="services" class="py-24 bg-[#0f0f1a]">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-4xl md:text-5xl font-serif font-bold text-center gold-text mb-16">Services</h2>
        <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
          <div class="text-center p-6">
            <div class="w-16 h-16 mx-auto mb-4 rounded-full bg-[#D4AF37]/10 flex items-center justify-center">
              <span class="text-2xl">🛎️</span>
            </div>
            <h3 class="font-semibold mb-2">24/7 Concierge</h3>
            <p class="text-sm text-gray-400">Personalised assistance, from airport transfers to restaurant reservations.</p>
          </div>
          <div class="text-center p-6">
            <div class="w-16 h-16 mx-auto mb-4 rounded-full bg-[#D4AF37]/10 flex items-center justify-center">
              <span class="text-2xl">🧖</span>
            </div>
            <h3 class="font-semibold mb-2">Spa & Wellness</h3>
            <p class="text-sm text-gray-400">Traditional Turkish bath and massage treatments in‑house.</p>
          </div>
          <div class="text-center p-6">
            <div class="w-16 h-16 mx-auto mb-4 rounded-full bg-[#D4AF37]/10 flex items-center justify-center">
              <span class="text-2xl">🍽️</span>
            </div>
            <h3 class="font-semibold mb-2">Rooftop Café</h3>
            <p class="text-sm text-gray-400">Enjoy breakfast with a panoramic view of Istanbul.</p>
          </div>
          <div class="text-center p-6">
            <div class="w-16 h-16 mx-auto mb-4 rounded-full bg-[#D4AF37]/10 flex items-center justify-center">
              <span class="text-2xl">🚗</span>
            </div>
            <h3 class="font-semibold mb-2">Airport Shuttle</h3>
            <p class="text-sm text-gray-400">Private transfers to IST and SAW airports upon request.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Rooms Section -->
    <section id="rooms" class="py-24 bg-[#13132b]">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-4xl md:text-5xl font-serif font-bold text-center gold-text mb-4">Our Rooms</h2>
        <p class="text-gray-400 text-center max-w-2xl mx-auto mb-16">Each room is a sanctuary of comfort, blending modern amenities with timeless elegance. Book directly via WhatsApp for the best rates.</p>
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
          {rooms.map(room => (
            <div class="room-card bg-[#1a1a2e] rounded-xl overflow-hidden border border-[#D4AF37]/10 hover:border-[#D4AF37]/30 transition-all duration-300 shadow-xl group">
              <div class="overflow-hidden h-64 relative">
                <img src={room.img} alt={room.name} class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" />
                <div class="absolute top-4 right-4 gold-bg text-[#0f0f1a] font-bold px-3 py-1 rounded-full text-sm">{room.price}/night</div>
              </div>
              <div class="p-6">
                <h3 class="text-xl font-serif font-semibold mb-2">{room.name}</h3>
                <p class="text-gray-400 text-sm mb-6">{room.desc}</p>
                <a
                  href={`https://wa.me/${whatsappNumber}?text=${encodeURIComponent(`Hi, I'm interested in the ${room.name} (${room.price}/night). Please share availability.`)}`}
                  target="_blank"
                  class="book-btn block w-full text-center border border-[#D4AF37] gold-text font-medium py-3 rounded-lg transition duration-300 hover:bg-[#D4AF37] hover:text-[#0f0f1a]"
                >
                  Book Now via WhatsApp
                </a>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Common Areas / Rooftop -->
    <section class="py-24 bg-[#0f0f1a] text-center">
      <div class="max-w-4xl mx-auto px-4">
        <h2 class="text-4xl font-serif font-bold gold-text mb-6">Common Areas</h2>
        <p class="text-xl text-gray-300 mb-8">Experience breathtaking views from our rooftop. Whether it’s a morning coffee, an evening drink, or simply taking in the stunning cityscape – our terrace is your private window to Istanbul.</p>
        <img src="https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=1200&q=80" alt="Rooftop view" class="rounded-xl mx-auto shadow-2xl border border-[#D4AF37]/20" />
      </div>
    </section>

    <!-- Contact / Footer -->
    <section id="contact" class="py-24 bg-[#13132b] border-t border-[#D4AF37]/20">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h2 class="text-4xl font-serif font-bold gold-text mb-6">Contact Us</h2>
        <p class="text-gray-400 mb-12">Book online today and look forward to a relaxing stay with us.</p>
        <div class="grid md:grid-cols-3 gap-8 text-left">
          <div class="space-y-4">
            <h3 class="text-lg font-semibold border-b border-[#D4AF37]/30 pb-2">Address</h3>
            <p class="text-gray-400">Galata Mahallesi,<br/>Bereketzade Medresesi Sk. No:1,<br/>34421 Beyoğlu/İstanbul</p>
          </div>
          <div class="space-y-4">
            <h3 class="text-lg font-semibold border-b border-[#D4AF37]/30 pb-2">Contact</h3>
            <p class="text-gray-400"><span class="gold-text">Tel:</span> +90 54 000 27 000</p>
            <p class="text-gray-400"><span class="gold-text">Email:</span> info@galataistanbulhotel.com</p>
            <a href="https://wa.me/905400027000" target="_blank" class="inline-block mt-2 gold-bg text-[#0f0f1a] font-bold px-5 py-2 rounded-full text-sm hover:bg-[#b8960f] transition">
              Chat on WhatsApp
            </a>
          </div>
          <div class="space-y-4">
            <h3 class="text-lg font-semibold border-b border-[#D4AF37]/30 pb-2">Quick Links</h3>
            <ul class="text-gray-400 space-y-2">
              <li><a href="#home" class="hover:text-[#D4AF37]">Home</a></li>
              <li><a href="#about" class="hover:text-[#D4AF37]">About Us</a></li>
              <li><a href="#rooms" class="hover:text-[#D4AF37]">Rooms</a></li>
              <li><a href="#contact" class="hover:text-[#D4AF37]">Contact</a></li>
            </ul>
          </div>
        </div>
        <div class="mt-12 pt-8 border-t border-gray-800 text-gray-500 text-sm">
          &copy; 2025 Galata Istanbul Hotel. All rights reserved. Designed with ❤️ in Istanbul.
        </div>
      </div>
    </section>

  </body>
</html>
